{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/|assets/|sw\\.js|workbox-|registerSW\\.js|manifest\\.webmanifest|favicon\\.ico)(?!.*\\.).*)", "destination": "/index.html" }
  ]
}
