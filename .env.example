# .env.example — document every env var here, never real values.
# Copy to .env locally; set real values in Vercel project env config (Production/Preview/Development).
# Stack: Vite+React (frontend) · Hono on Vercel Functions (api/) · Drizzle · Neon · Clerk · PostHog · Sentry.

# ── Database (Neon) ──────────────────────────────────────────────────────────
DATABASE_URL=

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Publishable key is safe in the client bundle; secret key is server-side only (api/ routes).
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# phc_* project key is public by design (safe in client).
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.posthog.com

# ── Error tracking (Sentry) ───────────────────────────────────────────────────
VITE_SENTRY_DSN=
SENTRY_DSN=

# ── Build metadata (set automatically by Vercel — do not set manually) ───────
# VITE_COMMIT_SHA / VERCEL_GIT_COMMIT_SHA are populated by the Vercel build environment.
